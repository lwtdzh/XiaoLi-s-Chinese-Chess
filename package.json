
{
  "name": "xiaoli-chinese-chess",
  "version": "1.0.0",
  "description": "Chinese Chess game with multiplayer support on Cloudflare Pages",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:local": "npm run build && wrangler pages dev public --d1=DB=chinachess --local --port 8788",
    "db:init": "wrangler d1 execute chinachess --file=./schema.sql --local",
    "db:init:remote": "wrangler d1 execute chinachess --file=./schema.sql --remote",
    "deploy": "npm run build && wrangler pages deploy public",
    "clean": "rm -rf public"
  },
  "dependencies": {},
  "devDependencies": {
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@cloudflare/workers-types": "^4.20231218.0",
    "wrangler": "^3.0.0",
    "jsdom": "^23.0.0"
  }
}
